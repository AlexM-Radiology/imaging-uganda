---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Pagination from '../../components/Pagination.astro';
import PostList from '../../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const pageSize = 6;
  const allPosts = (
    (await getCollection('cases')) as Array<CollectionEntry<'cases'>>
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const totalPages = Math.ceil(allPosts.length / pageSize);

  return Array.from({ length: totalPages }, (_, index) => ({
    params: {
      page: String(index + 1),
    },
  }));
}

const PAGE_SIZE = 6;
const allPosts = (
  (await getCollection('cases')) as Array<CollectionEntry<'cases'>>
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const currentPage = Number(Astro.params.page ?? '1');
const safePage = Math.min(Math.max(currentPage, 1), totalPages);
const pageTitle =
  safePage === 1
    ? `Cases | ${SITE_TITLE}`
    : `Cases - Page ${safePage} | ${SITE_TITLE}`;
const pageDescription =
  safePage === 1
    ? SITE_DESCRIPTION
    : `Page ${safePage} of ultrasound cases from Imaging Uganda/Africa.`;
const startIndex = (safePage - 1) * PAGE_SIZE;
const posts = allPosts.slice(startIndex, startIndex + PAGE_SIZE);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9674508263125209" crossorigin="anonymous"></script>
  </head>
  <body>
    <Header />
    <main>
      <PostList items={posts} routePrefix="cases" />
      <Pagination currentPage={safePage} totalPages={totalPages} basePath="/cases" />
    </main>
    <Footer />
  </body>
</html>
