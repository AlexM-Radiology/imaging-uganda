---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('cases')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9674508263125209"
     crossorigin="anonymous"></script>
    <style>
      /* Global safety nets to kill side scrolling entirely */
      html, body {
        max-width: 100% !important;
        overflow-x: hidden !important;
        margin: 0;
        padding: 0;
      }

      main {
        width: 100% !important;
        max-width: 820px !important; /* Locks width to a clean, tight stream like Healthline */
        margin: 0 auto !important;
        box-sizing: border-box !important;
        padding: 5.5em 1em 3em 1em;
      }

      /* Reset any layout grids inherited from standard theme */
      main section {
        width: 100% !important;
        max-width: 100% !important;
      }

      ul {
        display: flex !important;
        flex-direction: column !important;
        gap: 2rem !important;
        list-style-type: none !important;
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
      }

      ul li {
        width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      ul li a {
        display: flex !important;
        flex-direction: row !important; /* Explicitly forces horizontal row */
        align-items: flex-start !important;
        gap: 1.5rem !important;
        text-decoration: none !important;
        color: inherit !important;
        width: 100% !important;
        box-sizing: border-box !important;
      }

      /* Left Side: Fixed Square Image Container */
      .image-wrapper {
        flex-shrink: 0 !important;
        width: 120px !important;
        height: 120px !important;
      }

      .image-wrapper img {
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
        border-radius: 16px !important;
      }

      /* Right Side: Flexible Content Container */
      .content-wrapper {
        display: flex !important;
        flex-direction: column !important;
        gap: 0.35rem !important;
        justify-content: center !important;
        flex: 1 !important; 
        min-width: 0 !important; /* Prevents text elements from pushing container wide */
        width: 0 !important; /* Strict constraint against layout stretching */
      }

      .category {
        margin: 0 !important;
        font-size: 0.95rem !important;
        font-weight: 600 !important;
        color: #007c89 !important; /* Distinctive teal hue */
        text-transform: capitalize !important;
      }

      .title {
        margin: 0 !important;
        font-size: 1.25rem !important;
        font-weight: 700 !important;
        line-height: 1.3 !important;
        color: #000000 !important;
        word-wrap: break-word !important;
        overflow-wrap: break-word !important;
        white-space: normal !important; /* Forces standard multiline text wrapping */
      }
      
      ul li a:hover .title {
        color: #007c89 !important; 
      }

      /* Mobile styling adjustments */
      @media (max-width: 600px) {
        ul {
          gap: 1.5rem !important;
        }
        ul li a {
          gap: 1rem !important;
        }
        .image-wrapper {
          width: 90px !important;
          height: 90px !important;
        }
        .title {
          font-size: 1.05rem !important;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <ul>
          {
            posts.map((post) => (
              <li>
                <a href={`/cases/${post.id}/`}>
                  {post.data.heroImage && (
                    <div class="image-wrapper">
                      <Image 
                        width={240} 
                        height={240} 
                        src={post.data.heroImage} 
                        alt="" 
                      />
                    </div>
                  )}
                  <div class="content-wrapper">
                    {post.data.category && (
                      <p class="category">{post.data.category}</p>
                    )}
                    <h2 class="title">{post.data.title}</h2>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>