---
// src/pages/search.astro
import { getCollection } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type SearchIndexItem = {
  id: string;
  title: string;
  description: string;
  category: string;
  heroImage: string;
  body: string;
  keywords: string[];
  keywordsText: string;
};

// 1. Fetch data from your collections
const articles = await getCollection('articles');
const cases = await getCollection('cases');
const equipment = await getCollection('equipment');

// 2. Normalize and pass raw image string sources down to the client index wrapper
const searchIndex: SearchIndexItem[] = [
  ...articles.map(item => ({
    id: `/articles/${item.id}/`,
    title: item.data.title,
    description: item.data.description,
    category: item.data.category || 'Article',
    heroImage: item.data.heroImage?.src || '', 
    body: item.body || '',
    keywords: item.data.keywords || [],
    keywordsText: item.data.keywords?.join(' ') || ''
  })),
  ...cases.map(item => ({
    id: `/cases/${item.id}/`,
    title: item.data.title,
    description: item.data.description,
    category: item.data.category || 'Clinical Case',
    heroImage: item.data.heroImage?.src || '',
    body: item.body || '',
    keywords: item.data.keywords || [],
    keywordsText: item.data.keywords?.join(' ') || ''
  })),
  ...equipment.map(item => ({
    id: `/equipment/${item.id}/`,
    title: item.data.title,
    description: item.data.description,
    category: item.data.category || 'Equipment',
    heroImage: item.data.images?.[0]?.src || '', 
    body: item.body || '',
    keywords: [] as string[],
    keywordsText: ''
  }))
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Results - {SITE_TITLE}</title>
</head>
<body>
  <Header />
  <main class="search-container">
    <h1 id="search-title">Search Results</h1>
    <p class="search-status" id="search-status">Searching for matching documents...</p>
    
    <div id="search-data-bridge" data-index={JSON.stringify(searchIndex)}></div>

    <section class="search-results-wrapper">
      <ul id="results-list">
        </ul>
    </section>
  </main>
  <Footer />
</body>
</html>

<script>
  import Fuse from 'fuse.js';

  interface SearchItem {
    id: string;
    title: string;
    description: string;
    category: string;
    heroImage: string;
    body: string;
    keywords: string[];
    keywordsText: string;
  }

  const bridgeElement = document.getElementById('search-data-bridge');
  const rawData = bridgeElement?.getAttribute('data-index');
  const searchIndex: SearchItem[] = rawData ? JSON.parse(rawData) : [];

  const urlParams = new URLSearchParams(window.location.search);
  const query = urlParams.get('q') || '';
  
  const titleHeading = document.getElementById('search-title');
  const statusText = document.getElementById('search-status');
  const resultsList = document.getElementById('results-list');

  if (query && titleHeading) {
    titleHeading.textContent = `Search Results for "${query}"`;
  }

  const fuseOptions = {
    keys: [
      { name: 'title', weight: 1.0 },
      { name: 'category', weight: 0.6 },
      { name: 'description', weight: 0.4 },
      { name: 'keywordsText', weight: 0.8 },
      { name: 'body', weight: 0.1 }
    ],
    threshold: 0.2,
    distance: 50,
    ignoreLocation: false,
    minMatchCharLength: 3,
    findAllMatches: false
  };

  if (searchIndex.length > 0 && resultsList && statusText) {
    const cleanQuery = query.trim();

    if (!cleanQuery) {
      statusText.textContent = "Please enter a clinical symptom, modality, or equipment name above to search.";
      resultsList.innerHTML = "";
    } else {
      const queryLower = cleanQuery.toLowerCase();
      const keywordMatches = searchIndex.filter((item) =>
        item.keywords.some((keyword) => keyword.toLowerCase().includes(queryLower))
      );
      const fuse = new Fuse(searchIndex, fuseOptions);
      const fuzzyMatches = fuse.search(cleanQuery) as Array<{ item: SearchItem }>;
      const results = [
        ...keywordMatches,
        ...fuzzyMatches.map(({ item }) => item).filter((item) => !keywordMatches.some((match) => match.id === item.id))
      ];

      if (results.length === 0) {
        statusText.textContent = `No matches found for "${cleanQuery}". Try searching for broader terms like "Ultrasound", "X-Ray", or "Thyroiditis".`;
        resultsList.innerHTML = "";
      } else {
        statusText.textContent = `Found ${results.length} relevant match(es).`;
        
        resultsList.innerHTML = results.map((item) => {
          return `
            <li>
              <a href="${item.id}">
                ${item.heroImage ? `
                  <div class="image-wrapper">
                    <img src="${item.heroImage}" alt="" loading="lazy" />
                  </div>
                ` : ''}
                <div class="content-wrapper">
                  ${item.category ? `<p class="category">${item.category}</p>` : ''}
                  <h2 class="title">${item.title}</h2>
                  ${item.description ? `<p class="description">${item.description}</p>` : ''}
                </div> 
              </a>
            </li>
          `;
        }).join('');
      }
    }
  }
</script>

<style>
  .search-container {
    max-width: 900px;
    margin: 100px auto 4rem auto;
    padding: 0 1.5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  h1 {
    font-size: 1.75rem;
    color: #000000;
    margin-bottom: 0.25rem;
    font-weight: 700;
  }

  .search-status {
    color: #555555;
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
  }

  #search-data-bridge {
    display: none;
  }

  /* Using :global to target dynamically injected HTML nodes inside the wrapper container */
  .search-results-wrapper :global(ul) {
    display: flex !important;
    flex-direction: column !important;
    gap: 2rem !important;
    list-style-type: none !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
  }

  .search-results-wrapper :global(ul li) {
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .search-results-wrapper :global(ul li a) {
    display: flex !important;
    flex-direction: row !important;      /* Forces side-by-side alignment */
    align-items: flex-start !important;   /* Matches top of image with top of heading text */
    gap: 1.5rem !important;
    text-decoration: none !important;
    color: inherit !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  /* Perfectly locked thumbnail constraints */
  .search-results-wrapper :global(.image-wrapper) {
    flex-shrink: 0 !important;
    width: 90px !important;  
    height: 90px !important; 
  }

  .search-results-wrapper :global(.image-wrapper img) {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    border-radius: 16px !important;
  }

  .search-results-wrapper :global(.content-wrapper) {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.25rem !important;
    justify-content: flex-start !important;
    flex: 1 !important;
    min-width: 0 !important;
    width: 0 !important;
  }

  .search-results-wrapper :global(.category) {
    margin: 0 !important;
    font-size: 0.9rem !important;
    font-weight: 600 !important;
    color: #007c89 !important;
    text-transform: capitalize !important;
  }

  .search-results-wrapper :global(.title) {
    margin: 0 !important;
    font-size: 1.2rem !important;
    font-weight: 700 !important;
    line-height: 1.3 !important;
    color: #000000 !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    white-space: normal !important;
  }

  .search-results-wrapper :global(.description) {
    margin: 0 !important;
    font-size: 0.95rem !important;
    font-weight: 400 !important;
    line-height: 1.4 !important;
    color: #555555 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
  }

  .search-results-wrapper :global(ul li a:hover .title) {
    color: #007c89 !important;
  }

  /* Mobile Rules */
  @media (max-width: 600px) {
    .search-results-wrapper :global(ul) {
      gap: 1.5rem !important;
    }
    .search-results-wrapper :global(ul li a) {
      gap: 1rem !important;
    }
    .search-results-wrapper :global(.image-wrapper) {
      width: 70px !important;  
      height: 70px !important;
    }
    .search-results-wrapper :global(.title) {
      font-size: 1.05rem !important;
    }
    .search-results-wrapper :global(.description) {
      font-size: 0.85rem !important;
      -webkit-line-clamp: 2 !important;
    }
  }
</style>