---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9674508263125209"
     crossorigin="anonymous"></script>
    <style>
      main {
        width: 100%;
        max-width: 600px; /* Aligns with a clean, readable mobile/desktop stream layout */
        margin: 0 auto;
        padding: 1rem;
      }
      ul {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li a {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        text-decoration: none;
        color: inherit;
      }
      .image-wrapper {
        flex-shrink: 0;
        width: 120px;
        height: 120px;
      }
      .image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 16px; /* Smooth rounded corners matching the reference image */
      }
      .content-wrapper {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        justify-content: center;
      }
      .category {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 600;
        color: #007c89; /* Teal/cyan brand color from the screenshot */
        text-transform: capitalize;
      }
      .title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.3;
        color: #000000;
      }
      
      /* Hover effects */
      ul li a:hover .title {
        color: #007c89; 
      }

      /* Responsive adjustment for extra tight mobile viewports */
      @media (max-width: 400px) {
        .image-wrapper {
          width: 90px;
          height: 90px;
        }
        .title {
          font-size: 1.1rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <ul>
          {
            posts.map((post) => (
              <li>
                <a href={`/articles/${post.id}/`}>
                  {post.data.heroImage && (
                    <div class="image-wrapper">
                      <Image 
                        width={240} 
                        height={240} 
                        src={post.data.heroImage} 
                        alt="" 
                      />
                    </div>
                  )}
                  <div class="content-wrapper">
                    {post.data.category && (
                      <p class="category">{post.data.category}</p>
                    )}
                    <h2 class="title">{post.data.title}</h2>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>