---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import profileImg from "../../assets/pishon-1.jpg";
import workImg from "../../assets/pishon-3.jpg";
import skillsImg from "../../assets/pishon-2.jpg";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mwanje Pishon - CV | Imaging Uganda/Africa</title>
  </head>
  <body>
    <Header />
    <div class="cv-container">
      <div class="cv-grid">
        <aside class="thumbnail-column">
          <Image
            src={profileImg}
            alt="Mwanje Pishon Profile Picture"
            class="profile-img"
          />

          <div class="header-text">
            <h1 class="name">MWANJE PISHON</h1>
            <p class="title">MEDICAL CV</p>
          </div>

          <div class="divider"></div>

          <div class="contact-info">
            <h3 class="contact-heading">Contacts</h3>
            <ul>
              <li>
                <strong>Tel:</strong>
                <a href="tel:+256779860502">+256779860502</a> / <a
                  href="tel:+256755591049">0755591049</a>
              </li>
              <li>
                <strong>Email:</strong>
                <a href="mailto:pishonmwanje@gmail.com"
                  >pishonmwanje@gmail.com</a>
              </li>
              <li><strong>Address:</strong> Kampala Uganda</li>
              <li>
                <strong>YouTube:</strong>
                <a
                  href="https://www.youtube.com/@pishonmwanje256"
                  target="_blank">Mwanje Pishon</a>
              </li>
              <li>
                <strong>Facebook:</strong>
                <a
                  href="https://www.facebook.com/mwanje.pishon/"
                  target="_blank">Mwanje Pishon</a>
              </li>
              <li>
                <strong>TikTok:</strong>
                <a href="https://www.tiktok.com/@shon25607" target="_blank"
                  >@shon25607</a
                > / <a href="https://www.tiktok.com/@shon2567" target="_blank"
                  >@shon2567</a>
              </li>
            </ul>
          </div>
        </aside>

        <main class="content-column">
          <section class="section">
            <h2 class="section-title">Introduction</h2>
            <p>
              Mwanje Pishon is a Ugandan by nationality male gender. I am a
              registered medical imaging technologist by Allied Health
              Profession Council-AHPC. I have vast experience in teaching,
              medical ultrasound and radiological examinations using the
              following modalities ultrasound scan, plain x ray, CT Scan, MRI,
              Mammography, Fluoroscopy.
            </p>
          </section>

          <section class="section">
            <h2 class="section-title">Education</h2>
            <div class="experience-item">
              <div class="experience-content">
                <div class="experience-text">
                  <ul class="main-list">
                    <li>
                      Bachelors of medical imaging-BMI from Ernest Cook
                      University former ECUREI.
                    </li>
                    <li>
                      Bachelor of science with education from Kampala
                      university.
                    </li>
                  </ul>

                  <p class="item-subtitle">Training courses.</p>
                  <ul class="sub-list">
                    <li>
                      Certificate of participation in clinical integrated
                      disease surveillance and response online course.
                    </li>
                    <li>
                      Certificate of attendance in advances in abdominal and
                      urogenital imaging, USOFARI/UGASON/WFUMB.
                    </li>
                    <li>
                      Certificate of participation in the annual radiography
                      Quiz 2022 Makerere University.
                    </li>
                    <li>
                      Certificate of attendance in the fetal cardiac ultrasound
                      hands on session at ECUREI by Ultrasound Africa.
                    </li>
                  </ul>
                </div>
                <Image
                  src={profileImg}
                  alt="Pishon at school"
                  class="experience-img"
                />
              </div>
            </div>
          </section>

          <section class="section">
            <h2 class="section-title">Work</h2>
            <div class="experience-item">
              <div class="experience-content">
                <div class="experience-text">
                  <ul class="main-list">
                    <li>
                      St Stephens Hospital COU Mpererwe as head of department
                      and Radiation safety officer-RSO.
                    </li>
                    <li>
                      Kiganda Maternity Clinic Kawempe supervisor sonography.
                    </li>
                    <li>Mityana General Hospital radiology private wing.</li>
                    <li>Kyantungo HCIV Mityana district sonography.</li>
                    <li>
                      Served at Kyamusisi HCIII Mityana district sonography.
                    </li>
                  </ul>
                </div>
                <Image
                  src={workImg}
                  alt="Pishon on duty"
                  class="experience-img"
                />
              </div>
            </div>
          </section>

          <section class="section">
            <h2 class="section-title">Skills and experience</h2>
            <div class="experience-item">
              <div class="experience-content">
                <div class="experience-text">
                  <ul class="main-list">
                    <li>Abdominal sonography and EFAST.</li>
                    <li>Obstetrics and gynecology sonography.</li>
                    <li>
                      Small parts and superficial sonography (breast, neck and
                      scrotal).
                    </li>
                    <li>Fetal cardiography.</li>
                    <li>Ocular sonography.</li>
                    <li>Fetal Doppler sonography.</li>
                    <li>Transvaginal sonography-TVS.</li>
                    <li>Trans rectal sonography-TRUS.</li>
                    <li>Advances abdominal and urogenital imaging.</li>
                    <li>Plain radiography and pattern recognition.</li>
                    <li>Special radiographic techniques.</li>
                    <li>CT scan techniques.</li>
                    <li>MRI techniques.</li>
                    <li>Mammography.</li>
                    <li>Fluoroscopy.</li>
                    <li>HDU bedside sonography and radiology techniques.</li>
                  </ul>
                </div>
                <Image
                  src={skillsImg}
                  alt="Medical Imaging Equipment"
                  class="experience-img"
                />
              </div>
            </div>
          </section>
        </main>
      </div>
    </div>
    <Footer />
  </body>
</html>

<style>
  /* UI Palette matching the uploaded image precisely */
  :root {
    --sidebar-bg: #1c4966; /* Deep steel blue */
    --section-heading: #173952;
    --border-blue: #4491c5;
    --accent-red: #d35400;
    --text-dark: #333333;
    --date-bg: #e9ecef;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  }

  body {
    color: var(--text-dark);
    line-height: 1.5;
    background-color: #f0f2f5;
    padding: 30px 15px;
  }

  .cv-container {
    max-width: 1050px;
    margin: 80px auto 0 auto; /* Added 80px top margin to push it below the header */
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  /* Left Column (Sidebar) Styling */
  .thumbnail-column {
    background-color: var(--sidebar-bg);
    color: white;
    padding: 40px 25px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-img {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    border: 4px solid rgba(255, 255, 255, 0.9);
    margin-bottom: 25px;
    object-fit: cover;
  }

  .header-text {
    text-align: center;
    width: 100%;
  }

  .name {
    font-size: 1.6rem;
    letter-spacing: 0.5px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .title {
    font-size: 1rem;
    opacity: 0.75;
    letter-spacing: 1px;
  }

  .divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.2);
    margin: 25px 0;
    width: 100%;
  }

  .contact-info {
    width: 100%;
  }

  .contact-heading {
    font-size: 1.1rem;
    margin-bottom: 15px;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding-bottom: 5px;
  }

  .contact-info ul {
    list-style: none;
  }

  .contact-info li {
    margin-bottom: 12px;
    font-size: 0.88rem;
    word-break: break-all;
  }

  .contact-info a {
    color: #76e4ff;
    text-decoration: none;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  /* Right Column (Main content) Styling */
  .content-column {
    padding: 40px;
  }

  .section {
    margin-bottom: 35px;
  }

  .section-title {
    color: var(--section-heading);
    font-size: 1.4rem;
    margin-bottom: 18px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--border-blue);
    position: relative;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 45px;
    height: 2px;
    background-color: var(--accent-red);
  }

  .experience-item {
    margin-bottom: 20px;
  }

  .experience-content {
    display: flex;
    gap: 25px;
    justify-content: space-between;
  }

  .experience-text {
    flex: 1;
  }

  .experience-img {
    width: 125px;
    height: 125px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid #ddd;
    align-self: flex-start;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  /* Layout styling for list items inside Sections */
  .main-list,
  .sub-list {
    padding-left: 20px;
  }

  .main-list li {
    margin-bottom: 8px;
    font-size: 0.95rem;
  }

  .nested-job-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 15px;
    margin-bottom: 5px;
  }

  .item-title {
    font-size: 1.05rem;
    color: #2c3e50;
    font-weight: 600;
  }

  .item-date {
    font-size: 0.85rem;
    color: #555;
    background-color: var(--date-bg);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .item-subtitle {
    font-size: 0.95rem;
    color: var(--border-blue);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .sub-list li {
    margin-bottom: 6px;
    font-size: 0.9rem;
    color: #444;
  }

  /* Media Breakpoints for Responsiveness */
  @media (max-width: 850px) {
    .cv-grid {
      grid-template-columns: 1fr;
    }

    .thumbnail-column {
      padding: 30px;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 20px;
    }

    .profile-img {
      width: 110px;
      height: 110px;
      margin-bottom: 0;
    }

    .header-text {
      text-align: left;
      flex: 1;
    }

    .divider {
      display: none;
    }

    .contact-info {
      margin-top: 10px;
    }
  }

  @media (max-width: 600px) {
    .experience-content {
      flex-direction: column-reverse;
      gap: 15px;
    }

    .experience-img {
      width: 100%;
      max-width: 180px;
      height: 120px;
    }

    .nested-job-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 5px;
    }
  }
</style>
