---
// Ssenyonga Henry - Medical CV Component
// You can copy/paste this directly into an Astro page (e.g., src/pages/cv-henry.astro)

import Header from '../../components/Header.astro';
import { Image } from 'astro:assets';
import profileImg from '../../assets/henry-1.jpg'; // Using the asset path allocated for Henry in your about page
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ssenyonga Henry - CV | Imaging Uganda/Africa</title>
</head>
<body>
    <Header />
    <div class="cv-container">
        <div class="cv-grid">
            <aside class="thumbnail-column">
                <Image src={profileImg} alt="Ssenyonga Henry Profile Picture" class="profile-img" />
                
                <div class="header-text">
                    <h1 class="name">SSENYONGA HENRY</h1>
                    <p class="title">MEDICAL CV</p>
                </div>
                
                <div class="divider"></div>
                
                <div class="contact-info">
                    <h3 class="contact-heading">Contacts</h3>
                    <ul>
                        <li><strong>Tel:</strong> <a href="tel:+25675576587">+25675576587</a></li>
                        <li><strong>Email:</strong> <a href="mailto:ssenyongah@yahoo.com">ssenyongah@yahoo.com</a></li>
                        <li><strong>Address:</strong> Kampala</li>
                    </ul>
                </div>
            </aside>
            
            <main class="content-column">
                <section class="section">
                    <h2 class="section-title">Introduction</h2>
                    <p>Ssenyonga Henry is a Ugandan by nationality male gender. I am a registered medical radiographer. I diagnose using the following imaging modalities: ultrasound scan, plain X-ray, CT scan, MRI, Mammography, and Fluoroscopy. I am also the CEO of Rem Medical Solutions, dealing in all medical equipment across Africa based in Uganda. Furthermore, I run other business ventures in Uganda.</p>
                </section>
                
                <section class="section">
                    <h2 class="section-title">Education</h2>
                    <div class="experience-item">
                        <div class="experience-content">
                            <div class="experience-text">
                                <ul class="main-list">
                                    <li>Bachelors of Medical Radiography.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
                
                <section class="section">
                    <h2 class="section-title">Work</h2>
                    <div class="experience-item">
                        <div class="experience-content">
                            <div class="experience-text">
                                <ul class="main-list">
                                    <li> Founder and CEO of Rem Medical Solutions (Kampala City and Mpererwe branch).</li>
                                    <li>Worked at St. Stephens Hospital COU Mpererwe.</li>
                                    <li>Worked at Doctors Medical Centre Mpererwe as Head of Department (HOD).</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="section">
                    <h2 class="section-title">Skills and experience</h2>
                    <div class="experience-item">
                        <div class="experience-content">
                            <div class="experience-text">
                                <ul class="main-list">
                                    <li>Abdominal sonography</li>
                                    <li>Obstetrics and gynecology sonography</li>
                                    <li>Small parts and superficial sonography (breast, neck and scrotal)</li>
                                    <li> Transvaginal sonography-TVS</li>
                                    <li>Trans rectal sonography-TRUS</li>
                                    <li>Plain radiography and pattern recognition</li>
                                    <li> CT scan techniques</li>
                                    <li>MRI techniques</li>
                                    <li>Mammography</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>
</body>
</html>

<style>
    /* UI Palette matching Mwanje Pishon's visual design exactly */
    :root {
        --sidebar-bg: #1c4966; /* Deep steel blue */
        --section-heading: #173952;
        --border-blue: #4491c5;
        --accent-red: #d35400;
        --text-dark: #333333;
        --date-bg: #e9ecef;
    }
    
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    body {
        color: var(--text-dark);
        line-height: 1.5;
        background-color: #f0f2f5;
        padding: 30px 15px;
    }
    
    .cv-container {
        max-width: 1050px;
        margin: 80px auto 0 auto; /* Pushed down exactly 80px to clear fixed header layout */
        background: white;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border-radius: 4px;
        overflow: hidden;
    }
    
    .cv-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        min-height: 100vh;
    }
    
    /* Left Column (Sidebar) Styling */
    .thumbnail-column {
        background-color: var(--sidebar-bg);
        color: white;
        padding: 40px 25px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .profile-img {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        border: 4px solid rgba(255, 255, 255, 0.9);
        margin-bottom: 25px;
        object-fit: cover;
    }
    
    .header-text {
        text-align: center;
        width: 100%;
    }
    
    .name {
        font-size: 1.4rem;
        letter-spacing: 0.5px;
        font-weight: 700;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    
    .title {
        font-size: 1rem;
        opacity: 0.75;
        letter-spacing: 1px;
    }
    
    .divider {
        height: 1px;
        background-color: rgba(255, 255, 255, 0.2);
        margin: 25px 0;
        width: 100%;
    }
    
    .contact-info {
        width: 100%;
    }
    
    .contact-heading {
        font-size: 1.1rem;
        margin-bottom: 15px;
        font-weight: 600;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 5px;
    }
    
    .contact-info ul {
        list-style: none;
    }
    
    .contact-info li {
        margin-bottom: 12px;
        font-size: 0.88rem;
        word-break: break-all;
    }
    
    .contact-info a {
        color: #76e4ff;
        text-decoration: none;
    }
    
    .contact-info a:hover {
        text-decoration: underline;
    }
    
    /* Right Column (Main content) Styling */
    .content-column {
        padding: 40px;
    }
    
    .section {
        margin-bottom: 35px;
    }
    
    .section-title {
        color: var(--section-heading);
        font-size: 1.4rem;
        margin-bottom: 18px;
        padding-bottom: 6px;
        border-bottom: 2px solid var(--border-blue);
        position: relative;
    }
    
    .section-title::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 45px;
        height: 2px;
        background-color: var(--accent-red);
    }
    
    .experience-item {
        margin-bottom: 20px;
    }
    
    .experience-content {
        display: flex;
        gap: 25px;
        justify-content: space-between;
    }
    
    .experience-text {
        flex: 1;
    }
    
    /* Layout styling for list items inside Sections */
    .main-list {
        padding-left: 20px;
    }
    
    .main-list li {
        margin-bottom: 10px;
        font-size: 0.95rem;
    }
    
    /* Media Breakpoints for Responsiveness */
    @media (max-width: 850px) {
        .cv-grid {
            grid-template-columns: 1fr;
        }
        
        .thumbnail-column {
            padding: 30px;
            flex-direction: row;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 20px;
        }
        
        .profile-img {
            width: 110px;
            height: 110px;
            margin-bottom: 0;
        }
        
        .header-text {
            text-align: left;
            flex: 1;
        }
        
        .divider {
            display: none;
        }
        
        .contact-info {
            margin-top: 10px;
        }
    }
</style>