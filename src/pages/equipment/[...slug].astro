---
// src/pages/equipment/[...slug].astro
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { USD_TO_UGX, DEFAULT_CURRENCY } from '../../consts';

export async function getStaticPaths() {
  const products = await getCollection('equipment');
  return products.map((product) => ({
    params: { slug: product.id },
    props: product,
  }));
}
type Props = CollectionEntry<'equipment'>;

const product = Astro.props;
const { title, description, price, currency, images = [], phoneNumber, inStock } = product.data;
const { Content } = await render(product);

// 1. Get the current page's absolute URL dynamically
const currentUrl = Astro.url.href;

// Determine displayed currency and convert if needed (USD -> UGX)
const originalCurrency = currency ?? DEFAULT_CURRENCY;
let displayCurrency = originalCurrency;
let displayPrice = price;
if (originalCurrency === 'USD') {
  displayCurrency = 'UGX';
  displayPrice = Math.round(price * USD_TO_UGX);
}

// 2. Updated helper function to accept and append the page URL
function getWhatsAppLink(phoneNumber: string, title: string, price: number, currency: string, productUrl: string) {
  const message = `Hello, I'm interested in purchasing the ${title} (${currency} ${price.toLocaleString()}). \n\nProduct Link: ${productUrl}\n\nCould you please provide more information?`;
  const encodedMessage = encodeURIComponent(message);
  return `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 6em 1em;
      }
      .product-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
      }
      @media (max-width: 768px) {
        .product-container { grid-template-columns: 1fr; gap: 1.5rem; }
      }
      
      /* --- CAROUSEL STYLES --- */
      .carousel-wrapper {
        position: relative;
        width: 100%;
        overflow: hidden;
        border-radius: 12px;
      }
      .carousel {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        -ms-overflow-style: none;  
        scrollbar-width: none;  
      }
      .carousel::-webkit-scrollbar {
        display: none;
      }
      .carousel-item {
        flex: 0 0 100%;
        scroll-snap-align: start;
      }
      .carousel-item img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
      }
      /* ----------------------- */

      .buy-btn {
        display: inline-block;
        background: #25D366;
        color: white;
        padding: 0.8rem 2rem;
        text-decoration: none;
        font-weight: 700;
        border-radius: 8px;
        margin: 1rem 0;
        transition: background 0.3s;
      }
      .buy-btn:hover {
        background: #128C7E;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="product-container">
        
        <div class="product-image">
          {images && images.length > 0 ? (
            <div class="carousel-wrapper" id="carouselWrapper">
              <div class="carousel" id="imageCarousel">
                {images.map((img: any, index: number) => (
                  <div class="carousel-item">
                    <Image src={img} alt={`${title} - Image ${index + 1}`} width={600} height={600} loading={index === 0 ? "eager" : "lazy"} />
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <p>No images available</p>
          )}
        </div>

        <div class="product-details">
          <h1 style="font-size: 1.8rem;">{title}</h1>
          <p class="price" style="font-size: 1.8rem; font-weight: bold; color: #007c89;">
            {displayCurrency} {displayPrice.toLocaleString()}
          </p>
          
          {inStock ? (
            /* 3. Pass 'currentUrl' as the fifth argument here */
            <a href={getWhatsAppLink(phoneNumber, title, displayPrice, displayCurrency, currentUrl)} target="_blank" rel="noopener noreferrer" class="buy-btn">
              Inquire on WhatsApp
            </a>
          ) : (
            <p style="color: red; font-weight: bold;">Out of Stock</p>
          )}
          
          <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 2rem 0;" />
          
          <div class="prose">
            <Content />
          </div>
        </div>
      </div>
    </main>
    <Footer />

    <script>
      const carousel = document.getElementById('imageCarousel');
      const wrapper = document.getElementById('carouselWrapper');
      
      if (carousel && wrapper) {
        let isPaused = false;
        const intervalTime = 3000;

        const autoSwipe = () => {
          if (isPaused) return;

          const itemWidth = carousel.clientWidth;
          const maxScrollLeft = carousel.scrollWidth - itemWidth;
          
          if (carousel.scrollLeft >= maxScrollLeft - 5) {
            carousel.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            carousel.scrollBy({ left: itemWidth, behavior: 'smooth' });
          }
        };

        let timer = setInterval(autoSwipe, intervalTime);

        const pauseTimer = () => { isPaused = true; };
        const resumeTimer = () => { isPaused = false; };

        wrapper.addEventListener('mouseenter', pauseTimer);
        wrapper.addEventListener('mouseleave', resumeTimer);
        wrapper.addEventListener('touchstart', pauseTimer, { passive: true });
        wrapper.addEventListener('touchend', resumeTimer);
        
        carousel.addEventListener('scroll', () => {
          clearInterval(timer);
          timer = setInterval(autoSwipe, intervalTime);
        }, { passive: true });
      }
    </script>
  </body>
</html>