---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, USD_TO_UGX, DEFAULT_CURRENCY } from '../../consts';
import { formatProductPrice, getWhatsAppLink } from '../../utils/equipment';

const products = await getCollection('equipment');
const siteOrigin = Astro.url.origin;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Medical Equipment - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        padding: 6em 1em 3em 1em;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        list-style-type: none;
        padding: 0;
      }
      .card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: #fff;
      }
      .image-wrapper {
        width: 100%;
        height: 200px;
        background: #f8fafc;
      }
      .image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
      .info {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
      }
      .title {
        font-size: 1.2rem;
        margin: 0 0 0.5rem 0;
        color: #000;
      }
      .price {
        font-size: 1.25rem;
        font-weight: 700;
        color: #007c89;
        margin-bottom: 1rem;
      }
      .btn {
        display: block;
        text-align: center;
        background: #007c89;
        color: white;
        padding: 0.6rem;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        margin-top: auto;
      }
      .btn:hover {
        background: #005f6a;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="section-header">
        <h2>Medical Equipment</h2>
        <p>Browse our curated collection of premium medical devices from trusted manufacturers</p>
      </div>
      <ul class="grid">
        {products.map((product) => {
          const specificProductUrl = `${siteOrigin}/equipment/${product.id}/`;
          const { displayCurrency, displayPrice } = formatProductPrice(
            product.data.price,
            product.data.currency,
            USD_TO_UGX,
            DEFAULT_CURRENCY,
          );

          return (
            <li class="card">
              <a href={`/equipment/${product.id}/`}>
                <div class="image-wrapper">
                  {product.data.images && product.data.images.length > 0 ? (
                    <Image 
                      width={400} 
                      height={300} 
                      src={product.data.images[0]} 
                      alt={product.data.title} 
                    />
                  ) : (
                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #94a3b8;">
                      No Image available
                    </div>
                  )}
                </div>
              </a>
              <div class="info">
                <h3 class="title">{product.data.title}</h3>
                <p class="price">{displayCurrency} {displayPrice.toLocaleString()}</p>
                <a 
                  href={getWhatsAppLink(product.data.phoneNumber, product.data.title, displayPrice, displayCurrency, specificProductUrl)} 
                  class="btn" 
                  target="_blank" 
                  rel="noopener noreferrer"
                >
                  Inquire on WhatsApp
                </a>
              </div>
            </li>
          );
        })}
      </ul>
    </main>
    <Footer />
  </body>
</html>
