---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

// 1. Destructure author and authorCv from Astro.props
const { title, description, keywords, pubDate, updatedDate, author, authorCv } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// 2. Dynamically build the author schema object based on availability
const authorSchema = author 
  ? {
      "@type": "Person",
      "name": author,
      ...(authorCv && { "url": new URL(authorCv, Astro.site).toString() })
    }
  : {
      "@type": "Organization",
      "name": SITE_TITLE,
    };

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL,
  },
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "inLanguage": "en-US",
  "author": authorSchema, // Use the dynamic author schema here
  "publisher": {
    "@type": "Organization",
    "name": SITE_TITLE,
  },
  "datePublished": new Date(pubDate).toISOString(),
  "dateModified": updatedDate ? new Date(updatedDate).toISOString() : new Date(pubDate).toISOString(),
});
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} keywords={keywords} schema={articleSchema} />

    <style>
      main {
        width: 100%;
        max-width: 720px;
        margin: 60px auto 0 auto;
        padding: 1em;
      }
      .prose {
        width: 100%;
        color: rgb(var(--gray-dark));
      }
      .title {
        margin-bottom: 0.5rem;
        padding: 1px;
        text-align: start;
        line-height: 1.2;
      }
      .title h1 {
        margin: 0.5rem 0;
        font-size: 25px;
        color: rgb(0, 191, 255);
      }
      /* Uniform line container for all metadata entries */
      .meta-data {
        margin-bottom: 0.5em;
        color: rgb(var(--gray));
        font-style: italic;
        display: block; /* Ensures the whole meta line stays together above the title */
      }
      .last-updated-on,
      .author-byline {
        display: inline;
      }
      .author-link {
        color: #007efc;;
        text-decoration: none;
      }
      .author-link:hover {
        text-decoration: underline;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="prose">
          <div class="title">
            <!-- Changed class name to meta-data to reflect everything inside it -->
            <div class="meta-data">
              <span>Published on: <FormattedDate date={pubDate} /></span>
              {
                updatedDate && (
                  <span class="last-updated-on">
                    {" "}• Last updated on <FormattedDate date={updatedDate} />
                  </span>
                )
              }
              {
                author && (
                  <span class="author-byline">
                    {" "}• By: {authorCv ? (
                      <a href={authorCv} class="author-link">{author}</a>
                    ) : (
                      <span>{author}</span>
                    )}
                  </span>
                )
              }
            </div>
            <h1>{title}</h1>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>