---
const { currentPage, totalPages, basePath } = Astro.props as {
  currentPage: number;
  totalPages: number;
  basePath: string;
};

// --- Sliding Window Logic ---
const maxVisiblePages = 4;
let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
let endPage = startPage + maxVisiblePages - 1;

// Adjust if the window goes past the total pages
if (endPage > totalPages) {
  endPage = totalPages;
  startPage = Math.max(1, endPage - maxVisiblePages + 1);
}

// Generate only the visible page numbers
const visiblePageNumbers = Array.from(
  { length: endPage - startPage + 1 },
  (_, index) => startPage + index
);

const prevPage = currentPage - 1;
const nextPage = currentPage + 1;
---

{totalPages > 1 ? (
  <nav class="pagination" aria-label="Pagination">
    <ul>
      {currentPage > 1 ? (
        <li>
          <a href={prevPage === 1 ? basePath : `${basePath}/${prevPage}`} rel="prev">
            Previous
          </a>
        </li>
      ) : null}

      {visiblePageNumbers.map((page) => (
        <li>
          <a
            class={page === currentPage ? 'active' : ''}
            href={page === 1 ? basePath : `${basePath}/${page}`}
          >
            {page}
          </a>
        </li>
      ))}

      {currentPage < totalPages ? (
        <li>
          <a href={`${basePath}/${nextPage}`} rel="next">
            Next
          </a>
        </li>
      ) : null}
    </ul>
  </nav>
) : null}

<style>
  .pagination {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .pagination ul {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.25rem;
    padding: 0;
    list-style: none;
    margin: 0;
    overflow-x: auto;
  }

  .pagination a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 0.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    text-decoration: none;
    color: inherit;
    background: white;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    font-size: 0.9rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pagination a:hover,
  .pagination a:focus-visible {
    background: rgba(0, 124, 137, 0.08);
    border-color: #007c89;
    outline: none;
  }

  .pagination a.active {
    background: #007c89;
    color: white;
    border-color: #007c89;
  }

  /* Desktop: Larger buttons with more padding */
  @media (min-width: 768px) {
    .pagination ul {
      gap: 0.5rem;
      overflow-x: visible;
    }

    .pagination a {
      min-width: 44px;
      height: 44px;
      padding: 0 0.75rem;
      font-size: 1rem;
    }
  }
</style>