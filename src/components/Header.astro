---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import SearchForm from "./SearchForm.astro";
---

<header id="main-header">
  <nav>
    <h2 class="site-title"><a href="/">{SITE_TITLE}</a></h2>
    
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <div class="internal-links" id="nav-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/articles">Articles</HeaderLink>
      <HeaderLink href="/cases">Cases</HeaderLink>
      <HeaderLink href="/equipment">Equipment</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      
      <SearchForm />
    </div>
  </nav>
</header>

<script>
  let lastScrollY = window.scrollY;
  const header = document.getElementById("main-header");
  const menuToggle = document.getElementById("menu-toggle");
  const navLinks = document.getElementById("nav-links");

  function closeMenu() {
    if (menuToggle && navLinks) {
      menuToggle.setAttribute("aria-expanded", "false");
      menuToggle.classList.remove("active");
      navLinks.classList.remove("show");
    }
  }

  // --- Hamburger Menu Logic ---
  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", (event) => {
      event.stopPropagation();
      const isExpanded = menuToggle.getAttribute("aria-expanded") === "true";
      menuToggle.setAttribute("aria-expanded", String(!isExpanded));
      menuToggle.classList.toggle("active");
      navLinks.classList.toggle("show");
    });
  }

  // --- Click Outside to Close Logic ---
  document.addEventListener("click", (event) => {
    const target = event.target as Node;
    if (navLinks?.classList.contains("show") && header && !header.contains(target)) {
      closeMenu();
    }
  });

  // --- Scroll Logic ---
  window.addEventListener("scroll", () => {
    if (!header) return;
    if (navLinks?.classList.contains("show")) return;

    const currentScrollY = window.scrollY;

    if (currentScrollY <= 80) {
      header.classList.remove("scroll-down");
      header.classList.remove("scroll-up");
      return;
    }

    if (currentScrollY > lastScrollY) {
      header.classList.add("scroll-down");
      header.classList.remove("scroll-up");
    } else {
      header.classList.add("scroll-up");
      header.classList.remove("scroll-down");
    }

    lastScrollY = currentScrollY;
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    margin: 0;
    padding: 0;
    background: #2c3e50;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 15%);
    transition: transform 0.3s ease-in-out;
  }

  header:global(.scroll-down) {
    transform: translateY(-100%);
  }

  header:global(.scroll-up) {
    transform: translateY(0);
  }

  h2.site-title {
    margin: 0;
    font-size: 1.2em;
    z-index: 1001;
  }

  h2.site-title a {
    color: #ffffff !important;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    width: 100%;
    padding: 0 1em;
    margin: 0 auto;
    min-height: 60px;
    position: relative;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  nav a {
    padding: 1em 0.5em;
    color: #ffffff;
    border-bottom: 4px solid transparent;
    text-decoration: none;
    white-space: nowrap;
  }

  nav a.active {
    border-bottom-color: var(--accent);
  }

  /* --- Hamburger Button Styles --- */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 1rem;
    z-index: 1001;
  }

  .hamburger {
    position: relative;
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: background 0.2s ease-in-out;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    background: #ffffff;
    transition: transform 0.2s ease-in-out, top 0.2s ease-in-out;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  .menu-toggle.active .hamburger {
    background: transparent;
  }
  .menu-toggle.active .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }
  .menu-toggle.active .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  /* --- Responsive Breakpoint --- */
  @media (max-width: 768px) {
    nav {
      padding: 0 1rem;
    }

    .menu-toggle {
      display: block;
    }

    .internal-links {
      position: absolute;
      top: calc(100% + 0.25rem);
      left: 0;
      width: 100%;
      background: #2c3e50;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.25rem 0 1rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .internal-links.show {
      max-height: 450px;
    }

    nav a {
      display: block;
      padding: 1rem 1.5rem;
      border-bottom: none;
      border-left: 4px solid transparent;
    }

    nav a.active {
      border-bottom-color: transparent;
      border-left-color: var(--accent);
      background: rgba(255, 255, 255, 0.04);
    }
  }

  @media (max-width: 350px) {
    .site-title {
      display: none;
    }
  }
</style>