---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
const { items, routePrefix } = Astro.props as {
  items: Array<CollectionEntry<'articles'> | CollectionEntry<'cases'>>;
  routePrefix: string;
};
---

<section>
  <ul>
    {items.map((post) => (
      <li>
        <a href={`/${routePrefix}/${post.id}/`}>
          {post.data.heroImage && (
            <div class="image-wrapper">
              <Image width={240} height={240} src={post.data.heroImage} alt="" />
            </div>
          )}
          <div class="content-wrapper">
            {post.data.category && <p class="category">{post.data.category}</p>}
            <h2 class="title">{post.data.title}</h2>
            {post.data.description && <p class="description">{post.data.description}</p>}
          </div> 
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  ul {
    display: flex !important;
    flex-direction: column !important;
    gap: 2rem !important;
    list-style-type: none !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
  }

  ul li {
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  ul li a {
    display: flex !important;
    flex-direction: row !important;
    align-items: flex-start !important;
    gap: 1.5rem !important;
    text-decoration: none !important;
    color: inherit !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  .image-wrapper {
    flex-shrink: 0 !important;
    width: 120px !important;
    height: 120px !important;
  }

  .image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    border-radius: 16px !important;
  }

  .content-wrapper {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.35rem !important;
    justify-content: center !important;
    flex: 1 !important;
    min-width: 0 !important;
    width: 0 !important;
  }

  .category {
    margin: 0 !important;
    font-size: 0.95rem !important;
    font-weight: 600 !important;
    color: #007c89 !important;
    text-transform: capitalize !important;
  }

  .title {
    margin: 0 !important;
    font-size: 1.25rem !important;
    font-weight: 700 !important;
    line-height: 1.3 !important;
    color: #000000 !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    white-space: normal !important;
  }

  .description {
    margin: 0 !important;
    font-size: 0.95rem !important;
    font-weight: 400 !important;
    line-height: 1.4 !important;
    color: #555555 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
  }

  ul li a:hover .title {
    color: #007c89 !important;
  }

  @media (max-width: 600px) {
    ul {
      gap: 1.5rem !important;
    }
    ul li a {
      gap: 1rem !important;
    }
    .image-wrapper {
      width: 90px !important;
      height: 90px !important;
    }
    .title {
      font-size: 1.05rem !important;
    }
    .description {
      font-size: 0.85rem !important;
      -webkit-line-clamp: 1 !important;
    }
  }
</style>
