---
const today = new Date();
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-column">
      <h3 class="footer-title">Imaging Uganda/Africa</h3>
      <ul class="footer-links">
        <li><a href="/about">About Us</a></li>
        <li><a href="/about">Our Team</a></li>
        <li><a href="/about">Careers</a></li>
        <li><a href="/about">Press</a></li>
        <li><a href="/about">Contact</a></li>
      </ul>
    </div>
    
    <div class="footer-column">
      <h3 class="footer-title">Resources</h3>
      <ul class="footer-links">
        <li><a href="/articles">All Articles</a></li>
        <li><a href="/cases">Radiology Cases</a></li>
      </ul>
    </div>

    <div class="footer-column">
      <h3 class="footer-title">Connect</h3>
      <div class="social-links">
        <a href="https://twitter.com" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
        <a href="https://linkedin.com" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
        <a href="https://facebook.com" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="https://instagram.com" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://youtube.com" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
      <div class="newsletter">
        <h4>Subscribe to our newsletter</h4>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email address" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {today.getFullYear()} Imaging Uganda/Africa. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 4em 2em 2em 2em;
    background: linear-gradient(var(--gray-gradient)) no-repeat;
    color: rgb(var(--gray));
  }

  .footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2em;
    max-width: 1200px;
    margin: 0 auto;
    text-align: left;
  }

  .footer-title {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    color: rgb(var(--gray-dark));
  }

  .footer-links {
    list-style: none;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: rgb(var(--gray-dark));
  }

  .social-links {
    display: flex;
    gap: 1em;
    margin-bottom: 1.5em;
    font-size: 1.5rem;
  }

  .social-links a {
    text-decoration: none;
    color: rgb(var(--gray));
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .newsletter-form input {
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    flex: 1;
  }

  .newsletter-form button {
    padding: 0.5rem 1rem;
    background: rgb(var(--gray-dark));
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }

  .footer-bottom {
    border-top: 1px solid rgba(var(--gray), 0.2);
    margin-top: 3em;
    padding-top: 2em;
    text-align: center;
    font-size: 0.9rem;
  }

  /* Mobile adjustment */
  @media (max-width: 600px) {
    .footer-container {
      text-align: center;
    }
    .social-links {
      justify-content: center;
    }
    .newsletter-form {
      flex-direction: column;
    }
  }
</style>