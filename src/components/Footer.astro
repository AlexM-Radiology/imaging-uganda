---
const today = new Date();
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-column">
      <h3 class="footer-title">Imaging Uganda/Africa</h3>
      <ul class="footer-links">
        <li><a href="/about">About Us</a></li>
        <li><a href="/about">Our Team</a></li>
        <li><a href="/about">Careers</a></li>
        <li><a href="/about">Press</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
      </ul>
    </div>
    
    <div class="footer-column">
      <h3 class="footer-title">Resources</h3>
      <ul class="footer-links">
        <li><a href="/articles">All Articles</a></li>
        <li><a href="/cases">Radiology Cases</a></li>
      </ul>
    </div>

    <div class="footer-column">
      <h3 class="footer-title">Connect</h3>
      <div class="social-links">
        <a href="https://twitter.com" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
        <a href="https://linkedin.com" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
        <a href="https://facebook.com" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="https://instagram.com" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="https://youtube.com" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
      <div class="newsletter">
        <h4>Subscribe to our newsletter</h4>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email address" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {today.getFullYear()} Imaging Uganda/Africa. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 4em 2em 2em 2em;
    background: linear-gradient(var(--gray-gradient)) no-repeat;
    color: rgb(var(--gray));
  }

  .footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2em;
    max-width: 1200px;
    margin: 0 auto;
    text-align: left;
  }

  .footer-title {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    color: rgb(var(--gray-dark));
  }

  .footer-links {
    list-style: none;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: rgb(var(--gray-dark));
  }

  .social-links {
    display: flex;
    gap: 1em;
    margin-bottom: 1.5em;
    font-size: 1.5rem;
  }

  .social-links a {
    text-decoration: none;
    color: rgb(var(--gray));
  }

  .newsletter {
    margin-top: 1rem;
  }

  .newsletter h4 {
    margin: 0 0 0.5rem 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: rgb(var(--gray-dark));
  }

  .newsletter-form {
    display: flex;
    gap: 0.65rem;
    margin-top: 0.5rem;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .newsletter-form input {
    padding: 0.7rem 0.85rem;
    border: 1px solid rgba(var(--gray), 0.25);
    border-radius: 999px;
    flex: 1 1 220px;
    min-height: 44px;
    height: 44px;
    background: #ffffff;
    color: rgb(var(--gray-dark));
    font: inherit;
    line-height: 1.2;
    appearance: none;
    -webkit-appearance: none;
  }

  .newsletter-form button {
    padding: 0.7rem 1rem;
    background: #1f4d6b;
    color: #ffffff;
    border: 1px solid #1f4d6b;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    min-height: 44px;
    height: 44px;
    box-shadow: 0 4px 10px rgba(31, 77, 107, 0.18);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
  }

  .newsletter-form button:hover {
    background: #173952;
    color: #ffffff;
    transform: translateY(-1px);
  }

  .footer-bottom {
    border-top: 1px solid rgba(var(--gray), 0.2);
    margin-top: 3em;
    padding-top: 2em;
    text-align: center;
    font-size: 0.9rem;
  }

  /* Mobile adjustment */
  @media (max-width: 600px) {
    .footer {
      padding: 3rem 1rem 1.5rem;
    }

    .footer-container {
      text-align: center;
      gap: 1.25rem;
    }

    .footer-column {
      width: 100%;
    }

    .footer-title {
      margin-bottom: 0.75rem;
    }

    .footer-links li {
      margin-bottom: 0.35rem;
    }

    .social-links {
      justify-content: center;
      margin-bottom: 1rem;
    }

    .newsletter {
      margin-top: 0.75rem;
    }

    .newsletter-form {
      flex-direction: column;
      gap: 0.75rem;
      align-items: stretch;
    }

    .newsletter-form input {
      width: 100%;
      min-height: 40px;
      height: 40px;
      padding: 0.6rem 0.8rem;
      border-radius: 10px;
      font-size: 0.92rem;
      line-height: 1.1;
    }

    .newsletter-form button {
      width: 100%;
      min-height: 40px;
      height: 40px;
      border-radius: 10px;
      font-size: 0.92rem;
      line-height: 1.1;
    }
  }
</style>