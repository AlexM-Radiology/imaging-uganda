---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { pageTitle, description = 'Curriculum Vitae' } = Astro.props;
---

<html lang="en">
<head>
  <BaseHead title={pageTitle} description={description} />
</head>
<body>
  <Header />
  <div class="cv-container">
    <div class="cv-grid">
      <slot />
    </div>
  </div>
    <Footer />
  </body>
</html>

<style>
  :root {
    --sidebar-bg: #1c4966;
    --section-heading: #173952;
    --border-blue: #4491c5;
    --accent-red: #d35400;
    --text-dark: #333333;
    --date-bg: #e9ecef;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    color: var(--text-dark);
    line-height: 1.5;
    background-color: #f0f2f5;
    padding: 30px 15px;
    font-family: var(--font-atkinson, 'Atkinson', sans-serif);
  }

  .cv-container {
    max-width: 1050px;
    margin: 80px auto 0 auto;
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  .thumbnail-column {
    background-color: var(--sidebar-bg);
    color: white;
    padding: 40px 25px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-img {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    border: 4px solid rgba(255, 255, 255, 0.9);
    margin-bottom: 25px;
    object-fit: cover;
  }

  .header-text {
    text-align: center;
    width: 100%;
  }

  .name {
    font-size: 1.4rem;
    letter-spacing: 0.5px;
    font-weight: 700;
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .title {
    font-size: 1rem;
    opacity: 0.75;
    letter-spacing: 1px;
  }

  .divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.2);
    margin: 25px 0;
    width: 100%;
  }

  .contact-info {
    width: 100%;
  }

  .contact-heading {
    font-size: 1.1rem;
    margin-bottom: 15px;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding-bottom: 5px;
  }

  .contact-info ul {
    list-style: none;
  }

  .contact-info li {
    margin-bottom: 12px;
    font-size: 0.88rem;
    word-break: break-all;
  }

  .contact-info a {
    color: #76e4ff;
    text-decoration: none;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .content-column {
    padding: 40px;
  }

  .section {
    margin-bottom: 35px;
  }

  .section-title {
    color: var(--section-heading);
    font-size: 1.4rem;
    margin-bottom: 18px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--border-blue);
    position: relative;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 45px;
    height: 2px;
    background: var(--accent-red);
  }

  .experience-item {
    margin-top: 1rem;
  }

  .experience-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .experience-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nested-job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .item-title {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .item-date {
    font-size: 0.95rem;
    opacity: 0.75;
  }

  .item-subtitle {
    color: #555;
  }

  .main-list,
  .sub-list {
    list-style: disc inside;
    margin: 0;
    padding-left: 1rem;
  }

  .experience-img {
    width: 100%;
    max-width: 400px;
    border-radius: 12px;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .cv-grid {
      grid-template-columns: 1fr;
    }

    .cv-container {
      margin-top: 0;
      border-radius: 0;
      min-height: 100vh;
    }

    .content-column {
      padding: 25px;
    }
  }
</style>
